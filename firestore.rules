rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Single-user app sem autenticação. Os dados nao sao sensiveis (times,
    // pontuacoes de jogos amadores). Para evitar abuso da API key, recomenda-se
    // habilitar Firebase App Check com reCAPTCHA v3 no Console e proteger este
    // endpoint via App Check enforcement. Consulte o README.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
